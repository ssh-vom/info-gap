---
import { STREAMS } from '../streams';
const { guide } = Astro.props;

function fmtDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<a
  href={`/guides/${guide.id}/`}
  class="group block p-6 transition-colors"
  style="background: var(--bg);"
>
  <div class="flex items-start justify-between gap-6">
    <div class="flex-1">
      <div class="text-xs mb-2 uppercase tracking-wider" style="color: var(--text-soft);">
        {STREAMS.find((s) => s.slug === guide.data.stream)?.name ?? guide.data.stream}
      </div>
      <h2 class="text-xl font-semibold tracking-tight group-hover:text-[var(--maroon)] transition-colors">
        {guide.data.title}
      </h2>
      <p class="mt-1 text-sm" style="color: var(--text-soft);">
        {guide.data.author}{guide.data.role ? ` · ${guide.data.role}` : ''}
      </p>
      {guide.data.tags.length > 0 && (
        <p class="mt-3 text-xs" style="color: var(--text-soft);">
          {guide.data.tags.join('  ·  ')}
        </p>
      )}
    </div>
    <div class="text-xs text-right shrink-0 pt-1" style="color: var(--text-soft);">
      <div>{fmtDate(guide.data.published)}</div>
      {guide.data.readingTime && <div class="mt-1">{guide.data.readingTime}</div>}
    </div>
  </div>
</a>
