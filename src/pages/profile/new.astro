---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getDb, getProfile } from '../../lib/db';
import { getUser } from '../../lib/auth';

const user = await getUser(Astro.cookies);
if (!user) return Astro.redirect('/auth/linkedin');
const profile = await getProfile(getDb(), user.sub);
const roles = profile?.roleHistory.length ? profile.roleHistory : [{ company: '', title: '', start: '', end: '', description: '' }];
const csv = (xs?: string[]) => xs?.join(', ') ?? '';
const field = 'w-full px-3 py-2 rounded-lg text-sm bg-transparent';
const style = 'border: 1px solid var(--border); color: var(--text);';
---

<Layout title="Create profile · InfoGap">
  <section class="max-w-3xl mx-auto px-6 py-12 fade-up">
    <p class="text-xs uppercase tracking-wider mb-4" style="color: var(--text-soft);">Welcome</p>
    <h1 class="text-4xl font-bold tracking-tight">Create your profile</h1>
    <p class="mt-3" style="color: var(--text-soft);">LinkedIn gave us your name/email. Add the useful stuff yourself.</p>

    <form id="profile" class="mt-8 grid gap-4">
      <div class="flex items-center gap-4 mb-2">
        {user.picture && <img src={user.picture} alt="" class="w-14 h-14 rounded-full" />}
        <div>
          <div class="font-medium">{user.name}</div>
          {user.email && <div class="text-sm" style="color: var(--text-soft);">{user.email}</div>}
        </div>
      </div>

      <input name="name" value={profile?.name ?? user.name} placeholder="Name" class={field} style={style} />
      <input name="headline" value={profile?.headline ?? ''} placeholder="Headline — Software intern, founder, etc." class={field} style={style} />
      <div class="grid sm:grid-cols-2 gap-3">
        <input name="program" value={profile?.program ?? ''} placeholder="Program" class={field} style={style} />
        <input name="gradYear" value={profile?.gradYear ?? ''} placeholder="Grad year" class={field} style={style} />
      </div>
      <div class="grid sm:grid-cols-2 gap-3">
        <input name="school" value={profile?.school ?? 'McMaster University'} placeholder="School" class={field} style={style} />
        <input name="location" value={profile?.location ?? ''} placeholder="Location" class={field} style={style} />
      </div>
      <div class="grid sm:grid-cols-2 gap-3">
        <input name="linkedinUrl" value={profile?.linkedinUrl ?? ''} placeholder="LinkedIn URL" class={field} style={style} />
        <input name="website" value={profile?.website ?? ''} placeholder="Website" class={field} style={style} />
      </div>
      <textarea name="bio" rows="5" placeholder="Short bio" class={field} style={style}>{profile?.bio ?? ''}</textarea>

      <div class="mt-4">
        <div class="flex items-center justify-between mb-2">
          <h2 class="font-semibold">Role history</h2>
          <button type="button" id="add-role" class="text-sm" style="color: var(--maroon);">+ Add role</button>
        </div>
        <div id="roles" class="grid gap-3">
          {roles.map((r) => (
            <div class="role-row grid gap-2 p-3 rounded-lg" style="border: 1px solid var(--border);">
              <div class="grid sm:grid-cols-2 gap-2">
                <input data-k="title" value={r.title} placeholder="Title" class={field} style={style} />
                <input data-k="company" value={r.company} placeholder="Company" class={field} style={style} />
              </div>
              <div class="grid sm:grid-cols-2 gap-2">
                <input data-k="start" value={r.start} placeholder="Start — 2025-05" class={field} style={style} />
                <input data-k="end" value={r.end} placeholder="End — 2025-08 or Present" class={field} style={style} />
              </div>
              <textarea data-k="description" rows="2" placeholder="What did you do?" class={field} style={style}>{r.description}</textarea>
            </div>
          ))}
        </div>
      </div>

      <input name="skills" value={csv(profile?.skills)} placeholder="Skills — comma separated" class={field} style={style} />
      <input name="interests" value={csv(profile?.interests)} placeholder="Interests — comma separated" class={field} style={style} />

      <div class="flex items-center gap-3 pt-3">
        <button class="px-4 py-2 rounded-lg text-sm font-semibold" style="background: var(--maroon); color: white;">Save profile</button>
        <span id="status" class="text-sm" style="color: var(--text-soft);"></span>
      </div>
    </form>
  </section>

  <script>
    const form = document.getElementById('profile') as HTMLFormElement;
    const roles = document.getElementById('roles')!;
    const status = document.getElementById('status')!;
    const split = (s: FormDataEntryValue | null) => String(s || '').split(',').map((x) => x.trim()).filter(Boolean);

    document.getElementById('add-role')!.addEventListener('click', () => {
      const row = roles.querySelector('.role-row')!.cloneNode(true) as HTMLElement;
      row.querySelectorAll('input, textarea').forEach((el) => ((el as HTMLInputElement).value = ''));
      roles.append(row);
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = new FormData(form);
      const roleHistory = [...roles.querySelectorAll('.role-row')].map((row) =>
        Object.fromEntries([...row.querySelectorAll('[data-k]')].map((el) => [(el as HTMLElement).dataset.k, (el as HTMLInputElement).value]))
      );
      status.textContent = 'Saving…';
      const res = await fetch('/api/profile', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          name: f.get('name'), headline: f.get('headline'), program: f.get('program'), gradYear: f.get('gradYear'),
          school: f.get('school'), location: f.get('location'), linkedinUrl: f.get('linkedinUrl'), website: f.get('website'),
          bio: f.get('bio'), skills: split(f.get('skills')), interests: split(f.get('interests')), roleHistory,
        }),
      });
      if (res.ok) location.href = '/';
      else status.textContent = `Error: ${(await res.json().catch(() => ({}))).error || res.statusText}`;
    });
  </script>
</Layout>
