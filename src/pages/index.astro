---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import GuideCard from '../components/GuideCard.astro';
import KnowledgeMap from '../components/KnowledgeMap.astro';
import MentorPlane from '../components/mentor-plane/MentorPlane.tsx';
import { getDb, listPosts } from '../lib/db';
import { MENTORS } from '../lib/mentors';
import { getUser } from '../lib/auth';

const user = await getUser(Astro.cookies);
const guides = await listPosts(getDb());
---

<Layout chrome={!!user}>
  <!-- gate the intro: play once per session on a real page load, not on client-side nav back home.
       Runs before the veil is parsed, so the disabled case never flashes. -->
  <script is:inline>
    if (sessionStorage.getItem("infogap:introSeen")) {
      document.documentElement.classList.add("no-intro");
    } else {
      sessionStorage.setItem("infogap:introSeen", "1");
    }
  </script>

  <!-- soft load-in: logo bridges its gap, thesis over a darkened/blurred site, then the veil lifts as we zoom in -->
  <div class="intro-veil" aria-hidden="true">
    <svg class="intro-logo" viewBox="0 0 64 64" fill="none">
      <path class="il-right" d="M37 14 H52 L43 31 H28 Z" />
      <path class="il-left" d="M27 50 H12 L21 33 H36 Z" />
      <path class="il-bridge" d="M24 31 L40 21 L43 27 L27 37 Z" />
    </svg>
    <p class="intro-thesis">The knowledge they didn't hand you.</p>
  </div>

  <div class="intro-zoom">
    {user ? (
      <>
        <section class="hero-screen fade-up">
          <div class="max-w-6xl mx-auto px-6 w-full grid lg:grid-cols-[0.9fr_1.1fr] gap-12 items-center">
            <div>
              <p class="text-xs uppercase tracking-wider mb-5" style="color: var(--text-soft);">McMaster · curated</p>
              <h1 class="text-5xl sm:text-6xl font-bold tracking-tight leading-[1.02]">
                The knowledge they didn't hand you.
              </h1>
              <p class="mt-6 text-lg max-w-xl" style="color: var(--text-soft);">
                Practical paths from McMaster students and alumni who already figured it out.
              </p>
              <div class="mt-8 flex items-center gap-8 text-sm font-medium">
                <a href="#guides" class="underline underline-offset-4" style="color: var(--maroon);">
                  Explore guides →
                </a>
                <a href="#mentors" class="hover:opacity-70 transition-opacity" style="color: var(--text-soft);">
                  Meet mentors
                </a>
              </div>
            </div>

            <KnowledgeMap />
          </div>
          <a href="#mentors" class="hero-scroll-cue" aria-label="Scroll to meet mentors">
            <span>Scroll</span>
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M12 5v14M6 13l6 6 6-6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </section>

        <!-- the site breathes: scroll past the hero and you fall into a living field of mentors -->
        <section id="mentors" class="fade-up">
          <MentorPlane mentors={MENTORS} kicker="The network" title="A field of mentors, not a directory." client:only="react" />
        </section>
      </>
    ) : (
      <Fragment>
        {/* unauth: chrome-less scroll narrative. (1) hero opens zoomed in on the
            thesis + knowledge map, eases out as you scroll past; (2) the mentor
            plane is a still canvas; (3) the join card emerges from its center.
            All scroll choreography is native CSS view-timeline — no JS, no rAF. */}
        <a href="/auth/linkedin" class="mp-login-pill">Login →</a>

        <div class="mp-narrative">
        <section class="mp-hero fade-up">
          <div class="mp-hero-inner">
            <div class="mp-hero-fade">
            <div class="max-w-6xl mx-auto px-6 w-full grid lg:grid-cols-[0.9fr_1.1fr] gap-12 items-center">
              <div>
                <p class="text-xs uppercase tracking-wider mb-5" style="color: var(--text-soft);">McMaster · curated</p>
                <h1 class="text-5xl sm:text-6xl font-bold tracking-tight leading-[1.02]">
                  The knowledge they didn't hand you.
                </h1>
                <p class="mt-6 text-lg max-w-xl" style="color: var(--text-soft);">
                  Practical paths from McMaster students and alumni who already figured it out.
                </p>
              </div>
              <KnowledgeMap />
            </div>
          </div>
          </div>
          <a href="#join" class="hero-scroll-cue" aria-label="Scroll to meet the network">
            <span>Scroll</span>
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M12 5v14M6 13l6 6 6-6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </section>

        <section id="join" class="mp-immersive fade-up">
          <div class="mp-plane-reveal">
          <MentorPlane
            mentors={MENTORS}
            kicker="The network"
            title="A field of mentors, not a directory."
            client:only="react"
          />
          </div>

          {/* centered CTA: a placeholder person with a ? on their head. Styled
              exactly like a mentor card (dark fill, silhouette as the photo, caption
              overlay) so it reads as one of the field that steps forward on scroll. */}
          <a href="/auth/linkedin" class="mp-join-card" aria-label="Join the community">
            <svg class="mp-join-art" viewBox="0 0 270 340" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
              <rect width="270" height="340" fill="#0a0a0b"/>
              <text x="135" y="96" text-anchor="middle" font-family="var(--font-sans)" font-size="62" font-weight="700" fill="var(--gold)" opacity="0.92">?</text>
              <circle cx="135" cy="168" r="44" fill="var(--text-soft)" opacity="0.8"/>
              <path d="M66 340 C66 252 98 216 135 216 C172 216 204 252 204 340 Z" fill="var(--text-soft)" opacity="0.5"/>
            </svg>
            <div class="mp-join-cap">
              <span class="mp-join-eyebrow">Be the first</span>
              <span class="mp-join-title">Join the community</span>
              <span class="mp-join-sub">Add your face to the field.</span>
            </div>
          </a>
        </section>
        </div>
      </Fragment>
    )}

    {user && (
      <section id="guides" class="max-w-3xl mx-auto px-6 pb-24">
        <div class="flex justify-end mb-4">
          <a href="/edit" class="text-sm font-medium hover:opacity-70 transition-opacity" style="color: var(--maroon);">
            ✎ New post
          </a>
        </div>
        <div class="grid gap-px" style="background: var(--border);">
          {guides.map((post) => <GuideCard post={post} />)}
        </div>

        {guides.length === 0 && (
          <p class="text-center py-20" style="color: var(--text-soft);">
            No guides yet. <a href="/edit" class="underline" style="color: var(--maroon);">Write the first one →</a>
          </p>
        )}
      </section>
    )}
  </div>

  <style is:global>
    /* gated off: skip the intro entirely (client-side nav / already seen this session) */
    .no-intro .intro-veil { display: none; }
    .no-intro .intro-zoom { animation: none; }

    .intro-veil {
      position: fixed;
      inset: 0;
      z-index: 60;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1.6rem;
      padding: 1.5rem;
      text-align: center;
      pointer-events: none;
      animation: intro-veil 2.6s ease-in-out forwards;
    }
    .intro-logo { width: clamp(52px, 7vw, 76px); height: auto; }
    .intro-logo path { transform-box: fill-box; transform-origin: center; }
    /* the two halves slide together, then the gold bridge pops in to close the gap */
    .intro-logo .il-left  { fill: var(--maroon); animation: intro-logo-l 0.6s ease-out 0.1s both; }
    .intro-logo .il-right { fill: var(--maroon); animation: intro-logo-r 0.6s ease-out 0.1s both; }
    .intro-logo .il-bridge { fill: var(--gold); animation: intro-logo-b 0.5s cubic-bezier(.34,1.56,.64,1) 0.55s both; }

    .intro-thesis {
      max-width: 18ch;
      font-family: var(--font-sans);
      font-size: clamp(2rem, 6vw, 4rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.05;
      color: var(--text);
      animation: intro-thesis 2.6s ease-in-out forwards;
    }
    /* the site content gently zooms in behind the lifting veil */
    .intro-zoom { animation: intro-zoom 2.6s ease-in-out forwards; transform-origin: 50% 30%; }

    /* hero fills the opening viewport so the page opens on a full screen,
       then scroll carries you down into the mentor field. */
    .hero-screen {
      min-height: 100svh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      padding-block: 5rem;
    }
    .hero-scroll-cue {
      position: absolute;
      left: 50%;
      bottom: 1.6rem;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-soft);
      opacity: 0.8;
      transition: opacity 0.2s ease, color 0.2s ease;
    }
    .hero-scroll-cue svg { animation: hero-cue 2.2s ease-in-out infinite; }
    .hero-scroll-cue:hover { opacity: 1; color: var(--maroon); }
    @keyframes hero-cue { 0%, 100% { transform: translateY(0); opacity: 0.7; } 50% { transform: translateY(4px); opacity: 1; } }

    /* ---- unauth scroll narrative: native view-timeline, no JS ---- */
    /* login pill stays available across both sections */
    .mp-login-pill {
      position: fixed;
      top: 18px; right: 22px;
      z-index: 70;
      padding: 8px 16px;
      border-radius: 999px;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--maroon);
      background: color-mix(in srgb, var(--bg) 70%, transparent);
      border: 1px solid var(--border);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      text-decoration: none;
      transition: opacity 0.2s ease, transform 0.2s ease;
    }
    .mp-login-pill:hover { opacity: 0.85; transform: translateY(-1px); }

    /* The narrative wraps hero + plane. The plane's view-timeline (--plane) is
       hoisted here via timeline-scope so the hero's animations can share it —
       one progress value drives the whole transition, perfectly synchronized. */
    .mp-narrative { timeline-scope: --plane; }

    /* (1) hero: pinned sticky so the plane scrolls UP OVER it. Both sections
       then share screen space during the handoff → a true overlap dissolve
       instead of a moving seam. Same radial backdrop as the plane so the
       dissolve has no color shift. */
    .mp-hero {
      position: sticky;
      top: 0;
      z-index: 1;
      min-height: 100svh;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
      background:
        radial-gradient(120% 90% at 50% 40%, color-mix(in srgb, var(--bg-soft) 70%, transparent), transparent 70%),
        var(--bg);
    }
    .mp-hero-inner {
      width: 100%;
    }
    /* zoom-in start is a var so mobile can cap it at 1 — a full-width 1.25x
       scale clips the single-column hero off both viewport edges on phones. */
    @keyframes mp-hero-zoom {
      from { transform: scale(var(--hero-zoom-from, 1.25)); }
      to   { transform: scale(0.92); }
    }
    @media (max-width: 640px) {
      .mp-hero-inner { --hero-zoom-from: 1; } /* ponytail: settle, don't overflow */
    }
    /* hero content fades out as the plane covers it — gone by 70% of the
       plane's entry, so the hero is empty well before it's fully covered. */
    .mp-hero-fade {
      /* base opacity 1; the scroll-driven fade is gated in @supports below
         so iOS Safari (no scroll-driven animations) keeps the hero visible */
      opacity: 1;
    }
    @keyframes mp-hero-fade {
      from { opacity: 1; }
      to   { opacity: 0; }
    }

    /* (2) mentor plane scrolls up over the pinned hero. z-index 2 covers it.
       Same radial backdrop. */
    .mp-immersive {
      position: relative;
      z-index: 2;
      height: 100svh;
      overflow: hidden;
      view-timeline-name: --plane;
      view-timeline-axis: block;
      background:
        radial-gradient(120% 90% at 50% 40%, color-mix(in srgb, var(--bg-soft) 70%, transparent), transparent 70%),
        var(--bg);
    }
    /* plane reveals through the pinned hero: opaque by 60% of entry, so it's
       solid before the hero content is fully gone — the two overlap on screen. */
    .mp-plane-reveal {
      /* base opacity 1; scroll-driven reveal gated in @supports below */
      opacity: 1;
    }
    @keyframes mp-plane-reveal {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    .mp-join-card {
      position: absolute;
      left: 50%; top: 50%;
      transform: translate(-50%, -50%);
      z-index: 45;
      width: 270px;
      height: 340px;
      border-radius: 16px;
      /* same dark fill + shadow as .mp-card so it reads as one of the field */
      background: #000;
      box-shadow: 0 10px 30px rgba(0,0,0,0.35);
      overflow: hidden;
      text-decoration: none;
      cursor: pointer;
      transition: box-shadow 0.3s ease, transform 0.3s ease;
    }
    .mp-join-card:hover {
      box-shadow: 0 22px 60px rgba(0,0,0,0.55), 0 0 0 1px color-mix(in srgb, var(--gold) 40%, transparent);
    }
    /* shrink the join CTA with the field on small screens so it doesn't dwarf
       the cards. Caption text overrides live after the base rules below so they
       actually win (equal specificity → source order decides). */
    @media (max-width: 1000px) {
      .mp-join-card { width: 190px; height: 238px; border-radius: 12px; }
    }
    @media (max-width: 640px) {
      .mp-join-card { width: 150px; height: 188px; border-radius: 12px; }
    }
    .mp-join-art {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
      /* mirror the mentor cards' default dim/desaturate so it sits in the field */
      filter: brightness(0.55) saturate(0.85);
      transition: filter 0.3s ease;
    }
    .mp-join-card:hover .mp-join-art { filter: brightness(1.05) saturate(1.1); }
    /* caption overlay sits at the bottom like the mentor cards' cat/name */
    .mp-join-cap {
      position: absolute;
      left: 0; right: 0; bottom: 0;
      padding: 16px 18px 18px;
      display: flex;
      flex-direction: column;
      gap: 2px;
      text-align: left;
      background: linear-gradient(to top, rgba(0,0,0,0.78), rgba(0,0,0,0));
    }
    .mp-join-eyebrow {
      font-size: 0.62rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--gold);
      font-weight: 600;
    }
    .mp-join-title {
      font-family: var(--font-sans);
      font-size: 1.05rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: var(--text);
    }
    .mp-join-sub {
      font-size: 0.78rem;
      color: var(--text-soft);
    }
    /* scale the caption down with the shrunken card so it doesn't clip out the
       top. Placed after the base rules so source order makes these win. */
    @media (max-width: 1000px) {
      .mp-join-cap { padding: 12px 13px 13px; }
      .mp-join-eyebrow { font-size: 0.55rem; }
      .mp-join-title { font-size: 0.82rem; }
      .mp-join-sub { font-size: 0.64rem; }
    }
    @media (max-width: 640px) {
      .mp-join-cap { padding: 10px 11px 11px; gap: 1px; }
      .mp-join-eyebrow { font-size: 0.5rem; letter-spacing: 0.1em; }
      .mp-join-title { font-size: 0.82rem; line-height: 1.15; }
      .mp-join-sub { font-size: 0.62rem; }
    }
    @keyframes mp-join-emerge {
      from { opacity: 0; transform: translate(-50%, -50%) scale(0.92); filter: brightness(0.4); }
      to   { opacity: 1; transform: translate(-50%, -50%) scale(1);    filter: brightness(1); }
    }
    /* scroll-driven choreography only on engines that support it (Chromium).
       iOS Safari / older Firefox fall back to static, fully-visible states. */
    @supports (animation-timeline: view()) {
      .mp-hero-inner {
        animation: mp-hero-zoom ease-out both;
        animation-timeline: --plane;
        animation-range: entry 0% entry 100%;
      }
      .mp-hero-fade {
        animation: mp-hero-fade linear both;
        animation-timeline: --plane;
        animation-range: entry 0% entry 70%;
      }
      .mp-plane-reveal {
        animation: mp-plane-reveal linear both;
        animation-timeline: --plane;
        animation-range: entry 10% entry 60%;
      }
      .mp-join-card {
        animation: mp-join-emerge linear both;
        animation-timeline: --plane;
        animation-range: entry 45% entry 100%;
      }
    }
    @keyframes intro-logo-l { from { opacity: 0; transform: translate(-9px, 9px); } to { opacity: 1; transform: none; } }
    @keyframes intro-logo-r { from { opacity: 0; transform: translate(9px, -9px); } to { opacity: 1; transform: none; } }
    @keyframes intro-logo-b { from { opacity: 0; transform: scale(0.3); } to { opacity: 1; transform: none; } }

    @keyframes intro-veil {
      0%, 52%  { opacity: 1; background: rgba(8, 8, 9, 0.88);
                 backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); }
      100%     { opacity: 0; visibility: hidden; background: rgba(8, 8, 9, 0);
                 backdrop-filter: blur(0); -webkit-backdrop-filter: blur(0); }
    }
    @keyframes intro-thesis {
      0%   { opacity: 0; transform: scale(0.96); }
      16%  { opacity: 1; transform: scale(1); }
      52%  { opacity: 1; transform: scale(1); }
      100% { opacity: 0; transform: scale(1.14); }
    }
    @keyframes intro-zoom {
      0%, 40% { transform: scale(0.985); }
      100%    { transform: none; }
    }

  </style>
</Layout>
